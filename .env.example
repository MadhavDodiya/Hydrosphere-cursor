# HydroSphere Environment Configuration
# ====================================

# This project uses two separate .env files for backend and frontend.
# Copy this template to the respective directories.

# ------------------------------------------------------------------------------
# BACKEND (Copy to /backend/.env)
# ------------------------------------------------------------------------------

# General
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/hydrosphere

# Authentication
JWT_SECRET=your_super_secret_access_token_key
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key

# Frontend URL (Used for generating email links and CORS)
FRONTEND_URL=http://localhost:5173

# Email / SMTP (Required for notifications)
EMAIL_SERVICE=gmail
SMTP_USER=your_email@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx  # Gmail App Password (not your login password!)

# Optional Custom SMTP
# SMTP_HOST=smtp.yourprovider.com
# SMTP_PORT=587
# SMTP_SECURE=false

# Cloudinary (Required for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Razorpay (Required for billing)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret


# ------------------------------------------------------------------------------
# FRONTEND (Copy to /frontend/.env)
# ------------------------------------------------------------------------------

# Leave VITE_API_URL unset in local dev (Vite proxies /api requests)
# VITE_API_URL=https://your-production-api.com

# Optional: Socket.IO server origin (defaults to VITE_API_URL or http://localhost:5000)
# VITE_SOCKET_URL=https://your-production-api.com
