# --- Local dev (npm run dev) / preview (npm run preview) ---
# Leave VITE_API_URL unset: the app calls /api on the same host; Vite proxies to Express
# (proxy target = PORT from ../backend/.env, or override below)
# VITE_API_PROXY=http://127.0.0.1:5001

# --- Production build (SPA hosted separately from API) ---
# VITE_API_URL=https://your-api.example.com
