# Copy this file to `.env` and adjust values.
# Windows: copy .env.example .env
# macOS/Linux: cp .env.example .env

PORT=5000

# Local MongoDB (default)
MONGODB_URI=mongodb://127.0.0.1:27017/hydrosphere
# MongoDB Atlas example (uncomment and edit):
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/hydrosphere?retryWrites=true&w=majority

JWT_SECRET=change_this_to_a_long_random_string_in_production

# Production only: allowed browser origins (comma-separated), e.g. https://app.example.com
# FRONTEND_URL=https://app.example.com
