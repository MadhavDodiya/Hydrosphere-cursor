# Copy this file to `.env` and adjust values.
# Windows: copy .env.example .env
# macOS/Linux: cp .env.example .env

PORT=5000

# Local MongoDB (default)
MONGODB_URI=mongodb://127.0.0.1:27017/hydrosphere
# MongoDB Atlas example (uncomment and edit):
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/hydrosphere?retryWrites=true&w=majority

JWT_SECRET=change_this_to_a_long_random_string_in_production

# Cloudinary Configuration (Image Uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email / SMTP Configuration
# Use 'gmail' or another supported service, OR leave empty and set SMTP_HOST for custom SMTP
EMAIL_SERVICE=gmail
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Custom SMTP (Optional, overrides EMAIL_SERVICE if configured)
# SMTP_HOST=smtp.mailtrap.io
# SMTP_PORT=587
# SMTP_SECURE=false

# Optional sender identity
# EMAIL_FROM="HydroSphere Marketplace" <noreply@hydrosphere.com>

# Production only: allowed browser origins (comma-separated)
# FRONTEND_URL=https://app.example.com
